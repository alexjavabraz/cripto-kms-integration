# =============================================================================
# REQUIRED — a aplicação não inicia sem estas variáveis
# =============================================================================

# ARN ou ID da chave KMS assimétrica (ECC_SECG_P256K1 / SIGN_VERIFY)
# Usada como carteira da plataforma para deploy de contratos e transferências
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL JSON-RPC do nó Besu (ou qualquer nó EVM compatível)
DLT_RPC_ENDPOINT=http://besu-node.internal:8545

# =============================================================================
# AWS
# =============================================================================

AWS_REGION=us-east-1

# Override para ambientes air-gapped (VPC Interface Endpoint do SQS):
# AWS_SQS_ENDPOINT=https://vpce-XXXXX.sqs.us-east-1.vpce.amazonaws.com

# =============================================================================
# REDE DLT — Hyperledger Besu (rede privada)
# =============================================================================

# Chain ID configurado no genesis.json do Besu
DLT_CHAIN_ID=1337

# Gas limit por transação.
# Em rede privada com gas gratuito (MAX_FEE=0) não há custo — use valor alto
# para cobrir deploys de contratos complexos sem risco de "out of gas".
# Verifique o gasLimit do bloco no genesis.json do Besu e use valor menor.
# Recomendado para Besu privado: 10000000 (10 milhões)
DLT_GAS_LIMIT=10000000

# Preço do gas — manter 0 para redes privadas sem custo de gas (Besu IBFT/QBFT)
DLT_MAX_FEE_PER_GAS=0
DLT_MAX_PRIORITY_FEE_PER_GAS=0

# URL do block explorer (opcional — incluída nas respostas SQS para rastreabilidade)
DLT_EXPLORER_URL=http://explorer.internal

# Quantidade de token nativo enviada a carteiras novas para cobrir gas futuro
# Manter 0.001 para redes com gas ou 0 se não houver custo de gas
DLT_GAS_FUND_AMOUNT_ETH=0.001

# =============================================================================
# FILAS SQS — nomes podem ser sobrescritos (padrão: kms-<operação>)
# =============================================================================

SQS_TOKEN_CREATION_REQUEST=kms-token-creation-request
SQS_TOKEN_CREATION_RESPONSE=kms-token-creation-response
SQS_BALANCE_REQUEST=kms-balance-request
SQS_BALANCE_RESPONSE=kms-balance-response
SQS_TOKEN_EVENT_REQUEST=kms-token-event-request
SQS_TOKEN_EVENT_RESPONSE=kms-token-event-response
SQS_TOKEN_TRANSFER_REQUEST=kms-token-transfer-request
SQS_TOKEN_TRANSFER_RESPONSE=kms-token-transfer-response
SQS_ACCOUNT_CREATE_REQUEST=kms-account-create-request
SQS_ACCOUNT_CREATE_RESPONSE=kms-account-create-response
SQS_USER_TRANSFER_REQUEST=kms-user-transfer-request
SQS_USER_TRANSFER_RESPONSE=kms-user-transfer-response

# =============================================================================
# BYTECODE DOS CONTRATOS — obrigatório apenas para operações de deploy
# Compilar com Hardhat/Foundry e colar o bytecode do artefato aqui
# =============================================================================

# BYTECODE_ERC20=0x608060405234801561001057600080fd5b50...
# BYTECODE_ERC721=0x608060405234801561001057600080fd5b50...
# BYTECODE_ERC1155=0x608060405234801561001057600080fd5b50...

# =============================================================================
# OBSERVABILIDADE
# =============================================================================

SENTRY_DSN=
