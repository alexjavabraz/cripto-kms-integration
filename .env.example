# =============================================================================
# REQUIRED — a aplicação não inicia sem estas variáveis
# =============================================================================

# ARN ou ID da chave KMS assimétrica (ECC_SECG_P256K1 / SIGN_VERIFY)
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL JSON-RPC do nó Besu
DLT_RPC_ENDPOINT=http://besu-node.internal:8545

# ARN do tópico SNS FIFO para onde kms-integration publica as respostas
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:atoken-integracao-kms-sns-dev.fifo

# =============================================================================
# AWS
# =============================================================================

AWS_REGION=us-east-1

# Override para ambientes air-gapped (VPC Interface Endpoints):
# AWS_SQS_ENDPOINT=https://vpce-XXXXX.sqs.us-east-1.vpce.amazonaws.com
# AWS_SNS_ENDPOINT=https://vpce-XXXXX.sns.us-east-1.vpce.amazonaws.com

# =============================================================================
# SQS — fila de entrada (SNS entrega aqui, kms-integration lê daqui)
# =============================================================================

SQS_QUEUE_NAME=atoken-integracao-kms-sqs-dev.fifo

# =============================================================================
# REDE DLT — Hyperledger Besu (rede privada)
# =============================================================================

DLT_CHAIN_ID=1337

# Gas limit por transação — use valor alto pois gas é gratuito em rede privada
# (deve ser menor que o gasLimit do bloco configurado no genesis.json do Besu)
DLT_GAS_LIMIT=10000000

# Manter 0 para redes privadas sem custo de gas (Besu IBFT/QBFT)
DLT_MAX_FEE_PER_GAS=0
DLT_MAX_PRIORITY_FEE_PER_GAS=0

DLT_EXPLORER_URL=http://explorer.internal
DLT_GAS_FUND_AMOUNT_ETH=0.001

# =============================================================================
# BYTECODE DOS CONTRATOS — obrigatório apenas para operações de deploy
# =============================================================================

# BYTECODE_ERC20=0x608060405234801561001057600080fd5b50...
# BYTECODE_ERC721=0x608060405234801561001057600080fd5b50...
# BYTECODE_ERC1155=0x608060405234801561001057600080fd5b50...

# =============================================================================
# BANCO DE DADOS — PostgreSQL (RDS em produção, 192.168.15.5 local)
# =============================================================================

# Credenciais em produção são carregadas via AWS Secrets Manager:
# Secret name: /kms-integration/rds-credentials
# Secret value (JSON flat): {"DB_HOST":"...","DB_USERNAME":"kms_app","DB_PASSWORD":"...","DB_LIQUIBASE_PASSWORD":"..."}

DB_HOST=192.168.15.5
DB_PORT=5432
DB_NAME=kms_db
DB_USERNAME=kms_app
DB_PASSWORD=

# Usuário CI/CD com permissão DDL para executar as migrations do Liquibase
DB_LIQUIBASE_USER=dpl_devops_liquibase
DB_LIQUIBASE_PASSWORD=

# Override para VPC Interface Endpoint (air-gapped):
# AWS_SECRETSMANAGER_ENDPOINT=https://vpce-XXXXX.secretsmanager.us-east-1.vpce.amazonaws.com

# =============================================================================
# OBSERVABILIDADE
# =============================================================================

SENTRY_DSN=
