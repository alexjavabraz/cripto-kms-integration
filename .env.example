# AWS
AWS_REGION=us-east-1
KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
KMS_WALLET_ADDRESS=    # optional — derived from KMS public key if blank

# Client's permissioned DLT
DLT_RPC_ENDPOINT=http://dlt-node.internal:8545
DLT_CHAIN_ID=1337
DLT_EXPLORER_URL=http://explorer.internal
DLT_GAS_LIMIT=300000
DLT_MAX_FEE_PER_GAS=0
DLT_MAX_PRIORITY_FEE_PER_GAS=0
DLT_GAS_FUND_AMOUNT_ETH=0.001

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_SSL_ENABLED=false

# Queue names (must match BFF configuration)
QUEUE_TOKEN_CREATION=dfns_listen_token_creation_request
QUEUE_BALANCE=queue_get_balance
QUEUE_TOKEN_EVENT=token_event.queue
QUEUE_TOKEN_TRANSFER=dfns_listen_token_transfer_request
QUEUE_ACCOUNT_CREATE=dfns_listen_account_create_request
QUEUE_USER_TRANSFER=dfns_listen_user_transfer_request

# Exchange names (must match BFF configuration)
EXCHANGE_TOKEN_CREATION_REQUEST=bff_publish_token_creation_request
EXCHANGE_TOKEN_CREATION_RESPONSE=dfns_publish_token_creation_response
EXCHANGE_BALANCE_RESPONSE=balance_response
EXCHANGE_TOKEN_EVENT=token_event
EXCHANGE_TOKEN_EVENT_RESPONSE=token_event_response
EXCHANGE_TOKEN_TRANSFER_REQUEST=bff_publish_token_transfer_request
EXCHANGE_TOKEN_TRANSFER_RESPONSE=dfns_publish_token_transfer_response
EXCHANGE_ACCOUNT_CREATE_REQUEST=bff_publish_account_create_request
EXCHANGE_ACCOUNT_CREATE_RESPONSE=dfns_publish_account_create_response
EXCHANGE_USER_TRANSFER_REQUEST=bff_publish_user_transfer_request
EXCHANGE_USER_TRANSFER_RESPONSE=dfns_publish_user_transfer_response

# Token deployment bytecode (compiled constructor bytecode from hardhat/foundry)
BYTECODE_ERC20=0x...
BYTECODE_ERC721=0x...
BYTECODE_ERC1155=0x...

# Sentry (optional)
SENTRY_DSN=
